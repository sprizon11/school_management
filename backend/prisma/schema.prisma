generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEACHER
  PARENT
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

enum FeeInstallmentStatus {
  PAID
  PENDING
  UPCOMING
}

enum FeeStructureType {
  ANNUAL
  TERM
  QUARTERLY
}

enum AnnouncementAudience {
  TEACHERS
  TEACHERS_AND_PARENTS
}

model School {
  id            String         @id @default(cuid())
  name          String
  code          String         @unique
  address       String?
  city          String?
  phone         String?
  logoUrl       String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  classes       Class[]
  users         User[]
  announcements Announcement[]
}

model User {
  id           String    @id @default(cuid())
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id])
  email        String
  passwordHash String
  role         UserRole
  fullName     String
  phone        String?
  avatarUrl    String?
  createdAt     DateTime          @default(now())
  teacher       Teacher?
  parent        Parent?
  notifications AppNotification[]
  chatMessages  ChatMessage[]

  @@unique([schoolId, email])
}

model Teacher {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode String   @unique
  gender       Gender   @default(MALE)
  department   String
  subjects     String[]
  classes           Class[]                 @relation("ClassTeacher")
  teachingClasses   TeacherTeachingClass[]
  marks             Mark[]
  homework          Homework[]
  chatConversations ChatConversation[]
}

model TeacherTeachingClass {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   String

  @@unique([teacherId, classId])
}

model Class {
  id             String    @id @default(cuid())
  schoolId       String
  school         School    @relation(fields: [schoolId], references: [id])
  grade          Int
  section        String
  streamGroup    String    @default("")
  name           String
  category       String
  room           String?
  academicYear   String
  classTeacherId String?
  classTeacher   Teacher?  @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  students            Student[]
  homework            Homework[]
  teachingAssignments TeacherTeachingClass[]
  createdAt           DateTime               @default(now())

  @@unique([schoolId, grade, section, streamGroup, academicYear])
}

model Student {
  id                 String            @id @default(cuid())
  studentCode        String            @unique
  fullName           String
  email              String?
  phone              String?
  gender             Gender
  rollNumber         Int
  dateOfBirth        DateTime?
  bloodGroup         String?
  address            String?
  status             StudentStatus     @default(ACTIVE)
  avatarUrl          String?
  fatherName         String?
  fatherPhone        String?
  fatherOccupation   String?
  motherName         String?
  motherPhone        String?
  motherOccupation   String?
  parentAddress      String?
  emergencyContact   String?
  emergencyPhone     String?
  classId            String
  class              Class             @relation(fields: [classId], references: [id])
  attendance         AttendanceRecord[]
  marks              Mark[]
  feeAssignments     FeeAssignment[]
  parent             Parent?
  chatConversations  ChatConversation[]
  createdAt          DateTime          @default(now())
}

model Parent {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ChatConversation {
  id            String        @id @default(cuid())
  schoolId      String
  teacherId     String
  teacher       Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lastMessageAt DateTime?
  lastMessage   String?
  messages      ChatMessage[]

  @@unique([teacherId, studentId])
  @@index([schoolId, lastMessageAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId   String
  senderUser     User             @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime         @default(now())
  readAt         DateTime?

  @@index([conversationId, createdAt])
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime         @db.Date
  status    AttendanceStatus

  @@unique([studentId, date])
}

model Subject {
  id    String @id @default(cuid())
  name  String @unique
  marks Mark[]
}

model Mark {
  id         String  @id @default(cuid())
  studentId  String
  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject @relation(fields: [subjectId], references: [id])
  teacherId  String?
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  termLabel  String
  maxMarks   Int     @default(100)
  marks      Int
  grade      String
  remarks    String?
}

model Homework {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id])
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  title       String
  description String?
  dueDate     DateTime
  createdAt   DateTime @default(now())
}

model Announcement {
  id            String               @id @default(cuid())
  schoolId      String
  school        School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  authorId      String?
  title         String
  body          String
  postedBy      String
  audience      AnnouncementAudience @default(TEACHERS)
  eventDate     DateTime?
  createdAt     DateTime             @default(now())
  notifications AppNotification[]
}

model AppNotification {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcementId String?
  announcement   Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  title          String
  body           String
  readAt         DateTime?
  createdAt      DateTime      @default(now())

  @@index([userId, readAt])
}

model Event {
  id        String   @id @default(cuid())
  title     String
  startAt   DateTime
  endAt     DateTime?
  location  String?
  color     String?
  createdAt DateTime @default(now())
}

model FeeStructure {
  id           String           @id @default(cuid())
  type         FeeStructureType
  termLabel    String
  academicYear String
  totalAmount  Int
  assignments  FeeAssignment[]
}

model FeeAssignment {
  id             String              @id @default(cuid())
  studentId      String
  student        Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructureId String
  feeStructure   FeeStructure        @relation(fields: [feeStructureId], references: [id])
  feeCode        String              @unique
  installments   FeeInstallment[]
}

model FeeInstallment {
  id              String               @id @default(cuid())
  assignmentId    String
  assignment      FeeAssignment        @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  label           String
  amount          Int
  dueDate         DateTime
  status          FeeInstallmentStatus @default(PENDING)
  payments        FeePayment[]
}

model FeePayment {
  id             String         @id @default(cuid())
  installmentId  String
  installment    FeeInstallment @relation(fields: [installmentId], references: [id])
  amount         Int
  transactionId  String
  paidAt         DateTime       @default(now())
  method         String         @default("Online Payment")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  actorName String
  createdAt DateTime @default(now())
}
